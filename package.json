{
  "name": "culture-chain",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @culture-chain/web dev",
    "build": "pnpm --filter @culture-chain/web build",
    "typecheck": "pnpm --filter @culture-chain/web typecheck",
    "clean": "rm -rf node_modules apps/web/.next apps/web/out",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yaml,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.32.1"
}
