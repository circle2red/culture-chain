# ================================================================
# 本地开发环境变量（复制此文件为 .env.local，按需填写）
# 带 * 的是「立即启动」必填项，其余暂时留空也能跑
# ================================================================

# ── Web3 ────────────────────────────────────────────────────────
# * 从 https://cloud.walletconnect.com 免费申请（注册即得）
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# 本地 Hardhat 节点（pnpm contracts:node 启动后自动可用）
NEXT_PUBLIC_POLYGON_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_ID=31337

# 合约地址（pnpm contracts:deploy:local 部署后填入）
NEXT_PUBLIC_CONTRACT_CULTURE_NFT=
NEXT_PUBLIC_CONTRACT_MARKETPLACE=
NEXT_PUBLIC_CONTRACT_SHOP_REGISTRY=

# ── 数据库（docker-compose up postgres 启动）────────────────────
DATABASE_URL=postgresql://culturechain:localdev@localhost:5432/culturechain

# ── 搜索（docker-compose up meilisearch 启动）──────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=localdevkey

# ── IPFS（开发阶段用 mock，可暂不填）──────────────────────────
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs
PINATA_API_KEY=
PINATA_SECRET_KEY=

# ── 应用 ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ── 内容审核（开发阶段可留空，上传时跳过审核）────────────────
CONTENT_MODERATION_API_URL=
CONTENT_MODERATION_API_KEY=

# ── 平台收款地址 ────────────────────────────────────────────────
PLATFORM_FEE_ADDRESS=
