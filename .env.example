# ===========================
# 区块链 / Web3
# ===========================

# WalletConnect Project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Polygon RPC URL (Alchemy/Infura/QuickNode)
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# 当前链 ID (137 = Polygon Mainnet, 80001 = Mumbai)
NEXT_PUBLIC_CHAIN_ID=80001

# 合约地址（部署后填写）
NEXT_PUBLIC_CONTRACT_CULTURE_NFT=
NEXT_PUBLIC_CONTRACT_MARKETPLACE=
NEXT_PUBLIC_CONTRACT_SHOP_REGISTRY=

# ===========================
# IPFS / 存储
# ===========================

# Pinata (https://app.pinata.cloud/keys)
PINATA_API_KEY=
PINATA_SECRET_KEY=
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# Arweave 钱包密钥（用于永久存储备份）
ARWEAVE_WALLET_KEY=

# ===========================
# 数据库
# ===========================

DATABASE_URL=postgresql://user:password@localhost:5432/culturechain

# ===========================
# 搜索
# ===========================

MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=

# ===========================
# 内容审核
# ===========================

# 内容安全 API（如 Amazon Rekognition / 自建）
CONTENT_MODERATION_API_URL=
CONTENT_MODERATION_API_KEY=

# ===========================
# 应用配置
# ===========================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# 平台手续费接收地址
PLATFORM_FEE_ADDRESS=
